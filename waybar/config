{
    "layer": "bot",
    "spacing": 0,
    "height": 0,
    "margin-bottom": 8,
    "margin-top": 8,
    "position": "bottom",
    "margin-right": 8,
    "margin-left": 8,
    "width": 1200,

    "modules-left": ["hyprland/workspaces"],
    "modules-center": ["clock"],
    "modules-right": ["network", "battery", "pulseaudio"],

    "hyprland/workspaces" : {
        "all-outputs": false,
        "tooltip": false,
        "persistent-workspaces":{
        "*": 5
      }
    },

    "custom/applauncher": {
        "format": "◯",
        "on-click": "pgrep wofi >/dev/null 2>&1 && killall wofi || wofi --show drun --location=top -y 15",
        "tooltip": false
    },

    "clock": {
        "format": "{:%I:%M}",
        "tooltip": false
    },

    "network": {
        "format-wifi": "  {essid} {bandwidthDownBits}",
        "format-ethernet": "󰈁  {essid} {bandwidthDownBits}",
        "format-disconnected": "🛇 No Network",
        "interval": 5,
        "tooltip": false,
        "on-click": "kitty --app-id floating_window nmtui; focus"
    },

    "pulseaudio": {
    "scroll-step": 5,
    "max-volume": 150,
    "format": "{icon} {volume}%",
    "format-bluetooth": "{icon} {volume}%",
    "format-icons": [
      "󰖀",
      "󰕾"
    ],
    "nospacing": 1,
    "format-muted": "󰝟 Muted",
    "on-click": "pavucontrol",
    "tooltip": false
  },

  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity}%",
    "format-charging": "🗲 {capacity}%",
    "format-plugged": "🗲 {capacity}%",
    "format-alt": "{icon} {time}",
    "format-full": " {capacity}%",
    "format-icons": [
      "",
      "",
      "",
      "",
      ""
    ],
    "tooltip": "false"
  }
}
